#software
#blastn = source /anaconda3/bin/activate; conda activate panGenome; blastn
#samtools = source /anaconda3/bin/activate; conda activate panGenome; samtools
#bedtools = source /anaconda3/bin/activate; conda activate panGenome; bedtools
#nucmer = source /anaconda3/bin/activate; conda activate panGenome; bedtools
#bowtie2 = source /anaconda3/bin/activate; conda activate panGenome; bowtie2
#bowtieBuild = source /anaconda3/bin/activate; conda activate panGenome; bowtie2-build
#deltaFilter = source /anaconda3/bin/activate; conda activate panGenome; delta-filter
#initialize environment
IniEnv = source /miniconda3/bin/activate; conda activate nanoflow; module load samtools;
## The steps parameter controls the overall workflow execution
## 0 --> Full pipeline
## 1 --> Start from decontamination
## 2 --> Start from end alignment and mapping
Steps = 1 


#Build process
#//before start, you have to make sure that all the software are available in your PATH for current environment!
#//Thread setting depend on your memory and cpu conditions, several processes in this pipeline will run in multiple thread

buildThread = 10
suffix = bam

Assembletool = popins
PopinsPath = module load bifrost sickle bwakit samtools ; /software/PopIns2/popins2


#remove contaminate
##blastn process
##//blast index Path prefix
##//blast https://ftp.ncbi.nih.gov/blast/db/FASTA/nt.gz, make index。
##//makeblastdb -dbtype nucl -in nt/nt -out blastdb
##//To accelerate the workflow, we created an optimized fast version of the decontamination procedure.
Vrmt = slow
blastIdentity = 95
blastLength = 90

blastThread = 5
fastBlastindex = /blast_index/blastdb
evalue = 0.00001
outfmt = 7
maxTargetSeqs = 1
blastNThread = 5

## slow version
## ncbi key word: Keyword for retrieving other species; separate with '-'.
slowrmt = false
blastindex = /blast_index/blastdb
NcbiKeyWord = Homo-Primates-Mammalia
##taxi selection
##//info directory need to contain
##//1. nucl_gb.accession2taxid which is available in ftp://ftp.ncbi.nlm.nih.gov/pub/taxonomy/accession2taxid/;
##//2. rankedlineage.dmp, which is available in https://ftp.ncbi.nlm.nih.gov/pub/taxonomy/new_taxdump/.
accession = /info/nucl_gb.accession2taxid
lineage = /info/rankedlineage.dmp

##fast version


#Endmapping
ChrMappingRange = 3000

ContigTail = 150
MapContigTail = 150

endmapThread = 5 
## MapContigTail = 100 : the parameter in cpg panGenome.
## ContigTail = 150 : the parameter in cpg panGenome.
## hg38 reference genome index must be precomputed
## hg38 excludes alternative sequences; only 22 autosomes + sex chromosomes are used
Grch38Noalt = /G38Noalt/GenomeG38Noalt.fa
##nucmer region compile parameter;
nucmerL = 15
nucmerB = 1
nucmerC = 15
EndDist = 5